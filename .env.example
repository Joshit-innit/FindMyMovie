NODE_ENV=development
PORT=3000
TRUST_PROXY=1

# Comma-separated frontend URLs allowed to call the API.
# Example production value: https://your-netlify-site.netlify.app
FRONTEND_ORIGIN=http://localhost:5173

# API protection
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
JSON_BODY_LIMIT=100kb

# Aiven for MySQL or any managed MySQL-compatible database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=find_my_movie
DB_CONNECTION_LIMIT=10
DB_SSL=false

# Use either inline CA content or a CA file path when your provider requires it.
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# DB_SSL_CA_PATH=/etc/secrets/aiven-ca.pem
# DB_SSL_REJECT_UNAUTHORIZED=true

# Alternative: set DATABASE_URL or MYSQL_URL instead of DB_* values.
# DATABASE_URL=mysql://user:password@host:port/defaultdb

TMDB_API_KEY=
WATCHMODE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
